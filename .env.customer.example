# Customer-specific environment variables template
# Copy this file to .env.customer-NAME and fill in the values

# Customer identification
CUSTOMER_NAME=customer-01
DASHBOARD_PORT=9120

# Telegram configuration (unique per customer)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Mattermost configuration (optional)
MATTERMOST_TOKEN=your-mattermost-token-here
MATTERMOST_URL=https://your-mattermost-server.com

# Custom data volume name (optional - defaults to hermes-{CUSTOMER_NAME}-data)
CUSTOMER_DATA_VOLUME=hermes-customer-01-data

# API server configuration (optional)
# API_SERVER_KEY=your-api-server-key
